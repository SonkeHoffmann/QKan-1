            message=msg, level=Qgis.Info,&#xd;&#xd;&#xd;
        )&#xd;&#xd;&#xd;
        iface.messageBar().pushMessage("Information", msg, level=Qgis.Info)&#xd;&#xd;&#xd;
&#xd;&#xd;&#xd;
def saveProject():&#xd;&#xd;&#xd;
    pass&#xd;&#xd;&#xd;
&#xd;&#xd;&#xd;
def closeProject():&#xd;&#xd;&#xd;
