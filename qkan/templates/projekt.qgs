        <actionsetting name="Bild öffnen" id="{bb35f5ca-7e7f-44b7-bfaa-ffea0d960666}" icon="" action="[%foto_dateiname%]" capture="0" notificationMessage="" shortTitle="Bild öffnen" type="5" isEnabledOnlyWhenEditable="0">
