        <actionsetting notificationMessage="" isEnabledOnlyWhenEditable="0" type="5" name="Bild öffnen" id="{bb35f5ca-7e7f-44b7-bfaa-ffea0d960666}" capture="0" action="[%foto_dateiname%]" shortTitle="Bild öffnen" icon="">
