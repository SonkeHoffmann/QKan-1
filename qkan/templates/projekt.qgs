          <rule key="{7a315328-c986-4768-8f34-85184ac94014}" label="> 1:500" scalemaxdenom="500">
            <rule symbol="0" filter="&quot;entwart&quot; = 'Mischwasser'" key="{90add3db-d470-469a-aa61-fb145e19656f}" label="Mischwasser"/>
