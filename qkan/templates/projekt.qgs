        <actionsetting id="{bb35f5ca-7e7f-44b7-bfaa-ffea0d960666}" isEnabledOnlyWhenEditable="0" type="5" icon="" capture="0" notificationMessage="" shortTitle="Bild öffnen" action="[%foto_dateiname%]" name="Bild öffnen">
